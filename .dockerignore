# ============================================================
# .dockerignore — Keep the build context lean
# Prevents large/sensitive files from being sent to the Docker daemon
# ============================================================

# Version control
.git
.gitignore

# Dependencies — reinstalled inside the container
node_modules

# Local env files — NEVER bake secrets into the image
.env
.env.*
!.env.example

# Next.js build output — rebuilt inside the container
.next

# Prisma generated client — regenerated during build
src/generated

# Development / editor artifacts
.DS_Store
*.log
npm-debug.log*
.vscode
.idea
*.swp
*.swo

# Test and coverage artifacts
coverage
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Documentation (not needed in the runtime image)
docs
README.md

# Docker files themselves (no need to copy into image)
Dockerfile
compose.yml
compose.*.yml
