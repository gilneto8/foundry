// This is your Prisma schema file.
// Learn more at: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// USER
// Core identity record. Email is the unique identifier.
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   // null for OAuth-only accounts
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// SESSION
// Stateless JWT sessions are stored server-side as encrypted cookies.
// This table is used for database-backed session validation (secure checks).
// ---------------------------------------------------------------------------
model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
