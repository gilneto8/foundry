// This is your Prisma schema file.
// Learn more at: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Worker generator — produces a standard CJS client for the worker process.
// The worker does not use a bundler, so it cannot use the TypeScript-first
// "prisma-client" generator. This generator produces compiled .js files
// compatible with plain Node.js require().
generator workerClient {
  provider = "prisma-client-js"
  output   = "../worker/src/generated/prisma-cjs"
}


datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// USER
// Core identity record. Email is the unique identifier.
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   // null for OAuth-only accounts
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions            Session[]
  subscription        Subscription?
  documentReceipts    DocumentReceipt[]
  scrapeSubscriptions ScrapeSubscription[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// SESSION
// Stateless JWT sessions are stored server-side as encrypted cookies.
// This table is used for database-backed session validation (secure checks).
// ---------------------------------------------------------------------------
model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// SUBSCRIPTION STATUS
// ---------------------------------------------------------------------------
enum SubscriptionStatus {
  INACTIVE   // Default — no active subscription
  TRIALING   // Free trial active (future-proof)
  ACTIVE     // Paid and current
  PAST_DUE   // Payment failed — dunning in progress
  CANCELED   // Subscription explicitly canceled
}

// ---------------------------------------------------------------------------
// SUBSCRIPTION
// 1-to-1 with User. Stores all Stripe billing state.
// planKey mirrors the key in src/lib/subscription.ts PLANS config,
// so the app never has to reverse-engineer Stripe Price IDs.
// ---------------------------------------------------------------------------
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  planKey              String?            // e.g. "PRO" — maps to PLANS["PRO"]
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// DOCUMENT RECEIPT
// Audit chain for cryptographically-stamped documents (DocStamper).
// issuedAt is set BEFORE the PDF renders — that is the legally significant
// moment. contentHash is written AFTER rendering with the SHA-256 of the
// output PDF bytes.
// ---------------------------------------------------------------------------
model DocumentReceipt {
  id           String   @id @default(cuid())
  userId       String
  /// e.g. "TACIT_APPROVAL_DECLARATION", "TECHNICIAN_LIABILITY_SHIELD"
  documentType String
  /// Human-readable external reference, e.g. "<municipalityCode>:<submissionRef>"
  entityRef    String
  /// SHA-256 hex digest of the rendered PDF — written once rendering completes.
  /// null means the PDF job is still in-flight or failed.
  contentHash  String?
  /// The legally significant timestamp: recorded BEFORE Playwright launches.
  issuedAt     DateTime
  /// Local path or future S3 key to the stored PDF file.
  storagePath  String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityRef])
  @@map("document_receipts")
}

// ---------------------------------------------------------------------------
// SCRAPE SUBSCRIPTION
// A user's intent to monitor a specific URL for regulatory changes.
// The RegDocScraper worker polls all active subscriptions on a schedule.
// ---------------------------------------------------------------------------
model ScrapeSubscription {
  id        String   @id @default(cuid())
  userId    String
  /// Public URL to monitor (HTTPS, publicly accessible, no login required)
  url       String
  /// JSON array of lowercase keyword strings to match against page text
  /// e.g. ["uso do solo", "zonamento", "plano diretor"]
  keywords  String   // stored as JSON string; parse in application layer
  /// Optional CSS selector to narrow the scrape to a specific page region.
  /// null = scrape full visible text of the page body.
  selector  String?
  /// Human-readable label, e.g. "Câmara Municipal de Lisboa — PDM"
  label     String?
  /// When false, the subscription is paused (not polled). Default: true.
  active    Boolean  @default(true)
  /// SHA-256 of the last successfully scraped page text. null = never scraped.
  /// Used by the worker for change-detection: alert only when hash changes.
  lastHash       String?
  /// Timestamp of the last completed scrape attempt (success or failure).
  lastScrapedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts ScrapeAlert[]

  @@index([userId])
  @@index([active])
  @@map("scrape_subscriptions")
}

// ---------------------------------------------------------------------------
// SCRAPE ALERT
// A single keyword hit or page-change event detected by the RegDocScraper.
// One ScrapeSubscription can produce many ScrapeAlerts over time.
// ---------------------------------------------------------------------------
model ScrapeAlert {
  id             String   @id @default(cuid())
  subscriptionId String
  /// SHA-256 hash of the page content at the time of this scrape.
  /// Compare with the previous hash to detect changes.
  contentHash    String
  /// Keywords that were matched in this scrape. JSON array of strings.
  matchedKeywords String
  /// Short excerpt of the page text surrounding the first matched keyword.
  excerpt        String?
  /// True if this alert has been dispatched via the NOTIFY queue.
  notified       Boolean  @default(false)
  detectedAt     DateTime @default(now())

  subscription ScrapeSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([detectedAt])
  @@map("scrape_alerts")
}
