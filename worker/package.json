{
  "name": "foundry-worker",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ background job processor for the Foundry boilerplate",
  "main": "dist/worker.js",
  "scripts": {
    "prisma:sync": "test -d src/generated/prisma-cjs || (cd .. && npx prisma generate)",
    "dev": "npm run prisma:sync && tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/worker.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bullmq": "^5.52.3",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^21.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
