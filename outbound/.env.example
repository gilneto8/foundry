OUTBOUND_DB_USER=outbound
OUTBOUND_DB_PASSWORD=change_me_in_production
OUTBOUND_DB_NAME=outbound

# Run mode: "cron" runs on schedule, "once" exits after a single run
RUN_MODE=cron

# Categories to scrape (comma-separated)
# Options: real_estate, restaurants, transport
TARGETS=real_estate,restaurants,transport

# Scope
REGION=Portugal

# Scraper behaviour
MAX_RESULTS=100
REQUEST_DELAY=3

LOG_LEVEL=INFO
