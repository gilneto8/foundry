# ============================================================
# FOUNDRY ENVIRONMENT VARIABLES — EXAMPLE
# Copy this file to .env and fill in the values.
# ============================================================

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DB_NAME?schema=public"

# Session secret — used to sign JWT cookies.
# Generate with: openssl rand -base64 32
SESSION_SECRET="your-secret-key-here"

# Redis — BullMQ job queue broker
# Points to "redis" service name in Docker, or localhost for local dev
REDIS_URL="redis://localhost:6379"

# Public URL — used for Stripe redirect URLs, canonical URLs, and sitemap
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Stripe — Billing Layer ─────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) locally, live keys (sk_live_...) in production.

# Secret key — server-side only, never expose to the browser
STRIPE_SECRET_KEY="sk_test_YOUR_SECRET_KEY_HERE"

# Publishable key — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_PUBLISHABLE_KEY_HERE"

# Webhook secret — get this from the Stripe dashboard or `stripe listen --print-secret`
# See README Step 10 for local dev setup with the Stripe CLI
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET_HERE"

# Price IDs — one per subscription tier. Create prices in the Stripe dashboard:
# https://dashboard.stripe.com/products
#
# To add more tiers, uncomment the next line and add a matching entry to PLANS
# in src/lib/subscription.ts
STRIPE_PRICE_ID_PRO="price_YOUR_PRO_PRICE_ID_HERE"
# STRIPE_PRICE_ID_BUSINESS="price_YOUR_BUSINESS_PRICE_ID_HERE"

# ─── Email — SMTP Transport ──────────────────────────────────────────────────
# Nodemailer SMTP credentials. Works with any SMTP provider:
#   Resend:   smtp.resend.com:587  (user = "resend", pass = your API key)
#   Mailgun:  smtp.mailgun.org:587
#   AWS SES:  email-smtp.<region>.amazonaws.com:587
#   Postmark: smtp.postmarkapp.com:587
#
# Port guide:
#   587 → STARTTLS (recommended default — upgrade after connection)
#   465 → Implicit TLS (SSL from the start)
#
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password-or-api-key"
SMTP_FROM="Your App <noreply@yourdomain.com>"
